# Gaji Production Caddyfile
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 로컬 개발용
localhost {
    @monitor path /monitor*
    
    basic_auth @monitor {
        admin $2a$14$xvD5o9JzQkoCv.EM7ZMLJuowKwXScQuoFSiG1YsAS/QdkecYZZ.sG
    }
    
    handle @monitor {
        uri strip_prefix /monitor
        reverse_proxy monitor:5000
    }
    
    reverse_proxy backend:8080
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 프로덕션용
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

api.gaji.me {
    # CORS는 Spring Boot에서 처리하므로 Caddy에서는 제거
    # (중복 헤더 방지)

    # 모니터링 엔드포인트
    @monitor path /monitor*
    basic_auth @monitor {
        {$MONITOR_USERNAME} {$MONITOR_PASSWORD_HASH}
    }
    handle @monitor {
        uri strip_prefix /monitor
        reverse_proxy monitor:5000
    }

    # 백엔드 API (Core)
    handle /api/core/* {
        reverse_proxy backend:8080
    }

    # AI API (FastAPI direct)
    handle_path /api/ai/* {
        rewrite * /api{uri}
        reverse_proxy ai-service:8000
    }

    # 기본 라우팅 (하위 호환성 유지)
    reverse_proxy backend:8080 {
        health_uri /actuator/health
        health_interval 10s
        health_timeout 5s
        
        transport http {
            dial_timeout 5s
            response_header_timeout 60s
        }
    }

    # TLS 자동 인증서
    tls admin@gaji.me

    # 로깅
    log {
        output file /logs/api-access.log {
            roll_size 10mb
            roll_keep 5
        }
        format json
    }
}